# ─────────────────────────────────────────────
# RoosterMade Ledger — Environment Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
# Public URL of this installation (no trailing slash)
APP_URL=https://ledger.example.com

# Human-readable name shown in the admin UI and emails
APP_NAME=RoosterMade Ledger

# Environment: development | production
# Controls PHP error display and session security
APP_ENV=production

# ── API Authentication ────────────────────────
# Secret key for Bearer token auth on all API endpoints.
# Generate with: openssl rand -hex 32
API_KEY=

# ── Stripe ───────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Mail ─────────────────────────────────────
# Supported providers: resend | mailgun | postmark | ses
MAIL_PROVIDER=resend
MAIL_FROM=ledger@example.com
MAIL_FROM_NAME=RoosterMade Ledger

# Resend (MAIL_PROVIDER=resend)
MAIL_API_KEY=re_...

# Mailgun (MAIL_PROVIDER=mailgun)
# MAIL_API_KEY=                  # Mailgun API key
# MAIL_DOMAIN=mg.example.com     # Sending domain

# Postmark (MAIL_PROVIDER=postmark)
# MAIL_API_KEY=                  # Postmark Server API Token

# Amazon SES (MAIL_PROVIDER=ses)
# MAIL_API_KEY=                  # AWS access key ID
# AWS_SECRET_KEY=                # AWS secret access key
# AWS_REGION=us-east-1
